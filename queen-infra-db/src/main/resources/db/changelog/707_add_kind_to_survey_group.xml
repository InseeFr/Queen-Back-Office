<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Add the kind discriminator to survey_group.
         Allowed values match the GroupKind enum: CAMPAIGN or PARTITION.
         Existing rows are backfilled to CAMPAIGN. -->

    <!-- 1. Add the column (nullable until backfilled) -->
    <changeSet id="707-1-add-kind-column" author="davdarras">
        <addColumn tableName="survey_group">
            <column name="kind" type="VARCHAR(20)"/>
        </addColumn>
    </changeSet>

    <!-- 2. Backfill existing rows as CAMPAIGN -->
    <changeSet id="707-2-backfill-kind-as-campaign" author="davdarras">
        <sql>
            UPDATE survey_group SET kind = 'CAMPAIGN' WHERE kind IS NULL;
        </sql>
    </changeSet>

    <!-- 3. Set NOT NULL -->
    <changeSet id="707-3-not-null-kind" author="davdarras">
        <addNotNullConstraint
            tableName="survey_group"
            columnName="kind"
            columnDataType="VARCHAR(20)"/>
    </changeSet>

    <!-- Add short_label to survey_group.
         Business rule: shortLabel = provided value ?? group id. -->

    <!-- 4. Add the column (nullable, no NOT NULL constraint) -->
    <changeSet id="707-4-add-short-label-column" author="davdarras">
        <addColumn tableName="survey_group">
            <column name="short_label" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

    <!-- 5. Backfill existing rows with their id -->
    <changeSet id="707-5-backfill-short-label" author="davdarras">
        <sql>
            UPDATE survey_group SET short_label = id WHERE short_label IS NULL;
        </sql>
    </changeSet>

    <!-- 6. Set NOT NULL -->
    <changeSet id="707-6-not-null-short-label" author="davdarras">
        <addNotNullConstraint
            tableName="survey_group"
            columnName="short_label"
            columnDataType="VARCHAR(255)"/>
    </changeSet>

</databaseChangeLog>
